# Copy this file to .env and fill in real values. Never commit .env itself.
#
# NOTE: The local demo (scripts/run_local.py) runs fully OFFLINE and needs
# NONE of these. They only matter when you turn on the LLM reasoning layer
# or deploy the ADK graph.
#
# The web app (scripts/run_web.py, or `uvicorn smart_assignment.webapp.app:app`
# directly) loads a .env file in the current directory automatically -- no need
# to export these in your shell first.

# --- Web app mode (see smart_assignment/webapp) ---
#
# Selects the "brain" behind the chat web app (scripts/run_web.py):
# "llm"           → Phase 2 (DEFAULT): the real ADK agent drives a genuine
#                   multi-turn natural-language conversation, decides which
#                   pipeline tool to call, and escalates to a human when needed.
#                   Uses the LLM backend + credentials below; if none are
#                   detected it transparently falls back to deterministic mode,
#                   so the app still runs offline.
# "deterministic" → Phase 1: a no-LLM parser fills in address/cases/slot and
#                   runs the pipeline directly. Fully offline, no key.
# Either way the live step-by-step visualization is identical.
SMART_ASSIGNMENT_WEBAPP_MODE=llm

# --- LLM backend (see smart_assignment/shared/llm.py) ---
#
# "sage"     → Sysco enterprise-governed path via SageLlmRegistry (default).
#              Requires the three SAGE_* credentials below.
# "standard" → SMART_ASSIGNMENT_MODEL below is used directly. Either a bare
#              Gemini model name (requires GOOGLE_API_KEY or Vertex
#              credentials), or a litellm-style "<provider>/<model>" string
#              for any other provider (e.g. "openai/gpt-4o-mini",
#              "anthropic/claude-3-7-sonnet-latest") -- that provider's own
#              env vars apply (e.g. OPENAI_API_KEY), and this needs the
#              `litellm` extra installed: pip install -e ".[litellm]"
SMART_ASSIGNMENT_LLM_BACKEND=sage

# --- Sage backend credentials (required when SMART_ASSIGNMENT_LLM_BACKEND=sage,
# --- and SMART_ASSIGNMENT_USE_SAGE_GATEWAY is NOT set -- see the gateway
# --- sub-path below) ---
SAGE_CLIENT_ID=your_sage_client_id_here
SAGE_CLIENT_SECRET=your_sage_client_secret_here
SAGE_ENVIRONMENT=your_sage_environment_here

# Sage model identifier (Sage-prefixed under the direct-agent path above; a
# gateway-exposed model id, e.g. "gpt-4o", under the LLM Gateway path below)
SMART_ASSIGNMENT_SAGE_MODEL=sage-gemini-2.5-flash

# Diagnostic (off by default): when true, whenever the Sage SDK masks the model's
# real reply with its generic "Something went wrong" error string, log the true
# agent_response (e.g. a tool/function call the grounded path never offered). Only
# adds a log line -- changes no decision, value, or fallback.
# SMART_ASSIGNMENT_DEBUG_SAGE_RESPONSE=true

# --- Sage LLM Gateway sub-path (opt-in, off by default) ---
#
# When true (and SMART_ASSIGNMENT_LLM_BACKEND=sage), the sage call is routed
# through Sysco's enterprise LLM Gateway (the Sage SDK's `GatewayLlm`, an
# OpenAI-compatible litellm proxy with OAuth2 token injection) instead of
# SageLlmRegistry's direct call to one registered SAGE agent. Off reproduces
# the direct-agent path above exactly -- see shared/llm.py's module docstring.
# SMART_ASSIGNMENT_USE_SAGE_GATEWAY=true

# LLM Gateway credentials (required when SMART_ASSIGNMENT_USE_SAGE_GATEWAY=true;
# read directly by the Sage SDK, not by this repo's Config). LLM_GATEWAY_ENV is
# optional -- the SDK defaults it to "qa" ("prod" for the production gateway).
# LLM_GATEWAY_CLIENT_ID=your_llm_gateway_client_id_here
# LLM_GATEWAY_CLIENT_SECRET=your_llm_gateway_client_secret_here
# LLM_GATEWAY_ENV=qa

# ============================================================================
# Observability / tracing (opt-in, off by default)
# ============================================================================
# See smart_assignment/shared/tracing.py. Purely additive: tracing only observes,
# it never changes a decision, and any failure (SDK not installed, backend
# unreachable) silently degrades to no tracing. Requires the `observability`
# extra:  pip install -e ".[observability]"
#
# What gets traced when on: the conversational agent's turns and tool calls (via
# the ADK instrumentor) AND the grounded generate_text decision calls -- together
# in one connected trace.

# 1. Master switch. When true, tracing is set up on first agent build / LLM call.
# SMART_ASSIGNMENT_USE_TRACING=true

# 2. Exporter target -- choose EXACTLY ONE of (a) or (b).
#
#   (a) Vendor-neutral standard OTLP (keeps the backend swappable). Takes
#       precedence over (b) if both are set.
#
#       IMPORTANT: this must be the BASE url -- the OTLP/HTTP exporter appends
#       the signal path ("/v1/traces") itself. Adding that suffix yourself
#       (e.g. for a self-hosted Phoenix at http://localhost:6006) makes it
#       POST to /v1/traces/v1/traces, which the collector rejects with HTTP
#       405 -- and tracing will report itself as "configured" while every span
#       is silently dropped. Use OTEL_EXPORTER_OTLP_TRACES_ENDPOINT instead if
#       you need to pin a full URL including the path.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Basic%20...
#
#   (b) Convenience for a self-hosted Langfuse instance -- the OTLP endpoint and
#       Basic-auth header are derived from these three.
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# 3. Optional: the service.name reported on spans (defaults to "smart-assignment").
# OTEL_SERVICE_NAME=smart-assignment

# --- Standard backend ---

# Option A: Google AI Studio, bare Gemini model name (simplest for local dev)
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# GOOGLE_API_KEY=your_ai_studio_api_key_here

# Option B: Vertex AI, bare Gemini model name (production / Agent Runtime)
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# Option C: any litellm-supported provider, e.g. OpenAI
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# OPENAI_API_KEY=your_openai_api_key_here
# SMART_ASSIGNMENT_MODEL=openai/gpt-4o-mini

# Model identifier for the standard backend (see options above)
# Using the cheap flash-lite tier ($0.25/$1.50 per M input/output tokens vs.
# gemini-3.5-flash's higher flash pricing). gemini-2.5-flash-lite is NOT a
# cheaper substitute here -- it hits the same dead-model 404 as 2.5-flash did.
SMART_ASSIGNMENT_MODEL=gemini-3.1-flash-lite

# --- Per-role model overrides (optional) ---
# Assign the right model to the right task. Each unset var falls back to the
# global model above (sage_model under the sage backend), so leaving these
# blank keeps a single model everywhere. The LLM BACKEND stays global -- these
# only pick the model TIER, so each value must match the active backend's
# naming (a sage-prefixed id under sage; a bare/litellm name under standard).
# Roles: root_agent (the conversational agent), triage (the escalation-triage
# sub-agent), judgment (the grounded recommend/escalate decision), reasoning
# (the LLM-narrated reasoning trace), slotpick (the grounded delivery-slot pick),
# address_resolve (the grounded pick among a geocoder's address candidates),
# quality_judge (eval/test_quality.py's DeepEval G-Eval judge -- not a product
# decision-layer role like the others; advisory eval only).
# Example (standard backend): a strong model for the decision, a cheap one for
# the lightweight narration/triage.
# SMART_ASSIGNMENT_MODEL_ROOT_AGENT=gemini-3.5-flash
# SMART_ASSIGNMENT_MODEL_JUDGMENT=gemini-3.1-pro
# SMART_ASSIGNMENT_MODEL_TRIAGE=gemini-3.1-flash-lite
# SMART_ASSIGNMENT_MODEL_REASONING=gemini-3.1-flash-lite
# SMART_ASSIGNMENT_MODEL_SLOTPICK=gemini-3.5-flash
# SMART_ASSIGNMENT_MODEL_ADDRESS_RESOLVE=gemini-3.1-flash-lite
# SMART_ASSIGNMENT_MODEL_QUALITY_JUDGE=gemini-3.1-pro

# --- Address resolution (grounded typo/ambiguity correction) ---
#
# When ON (default), if the geocoder can't resolve the prospect's address, the
# agent asks a suggest-capable geocoder for its candidate matches and lets an LLM
# pick the closest one (constrained to that enumerated set + verified; see the
# `address_resolve` package) for the USER to confirm -- it never invents an
# address. On any failure -- feature unavailable, no candidate found, LLM/verify
# error -- it falls back to today's "ask the customer to double-check it."
# Set to false to reproduce that prior (no-correction) behavior exactly.
SMART_ASSIGNMENT_USE_ADDRESS_RESOLUTION=true

# --- Data source (see smart_assignment/integrations/route_capacity_client.py) ---
#
# Which route/capacity/tier data the workflow reads:
#   "mock"     → built-in Houston demo routes (fully offline, deterministic).
#   "cache"    → prepared ODI tables read from the on-disk snapshot ONLY
#                (data/dev/*, built via smart_assignment/data_prep/). No SQL, so
#                every call and every surface (adk web, the web app) sees the
#                SAME data -- use this for development and demos. **Default.**
#                If the snapshot is missing (e.g. a fresh checkout), it falls
#                back to "mock" with a warning instead of failing.
#   "live_sql" → pull from live SQL (requires creds.json at the repo root),
#                falling back to the cache per table on failure. Data can change
#                between runs, so two surfaces may show different routes -- use
#                only when you actually want fresh data.
SMART_ASSIGNMENT_DATA_SOURCE=cache
# Deprecated alias, still honored (mock | prepared→live_sql):
# SMART_ASSIGNMENT_ROUTE_SOURCE=mock
#
# Strict mode: when truthy, a data source that can't load FAILS instead of
# silently falling back to the mock demo routes. Off by default (the fallback
# above is a convenience for normal surfaces); the eval harness turns it on so an
# eval never scores against silently-substituted data (see eval/dataset.py).
# SMART_ASSIGNMENT_DATA_SOURCE_STRICT=0

# --- Eval dataset (see eval/dataset.py; only affects `python3 -m eval.*`) ---
#
# The eval suite pins its OWN dataset here, independent of SMART_ASSIGNMENT_DATA_SOURCE
# above, so eval results are reproducible and never inherit an ambient dev source.
#   "mock" → the committed offline routes + geocoder. **Default.**
# Add a scrubbed-synthetic or sanitized-real snapshot by registering it in
# eval/dataset.py, then naming it here. Each capture records the dataset it ran
# against (provenance), and tests/eval/test_dataset_lock.py enforces coverage.
# SMART_ASSIGNMENT_EVAL_DATASET=mock

# --- Geocoder (see smart_assignment/integrations/geocoding_client.py) ---
#
# How a street address becomes coordinates. Every surface (adk web, the web app,
# run_slot_recommendation) resolves through the same factory and loads this same
# .env, so they all use the same geocoder.
#   "census" → live US Census geocoder (real, accurate coordinates). **Default.**
#   "mock"   → deterministic offline geocoder (curated coords for the demo
#              addresses; a stable pseudo-point otherwise) for fully offline runs.
SMART_ASSIGNMENT_GEOCODER=census

# ds_utils run mode: local | dev | qa | perf | preprod | prod
# (see smart_assignment/data_prep/prep_delivery_data.py)
DS_UTILS_RUN_MODE=dev

# --- Workflow configuration (see smart_assignment/shared/config.py) ---

# Hard constraints
SMART_ASSIGNMENT_MAX_UTILIZATION=0.90     # max route utilization after adding a customer
SMART_ASSIGNMENT_MAX_SERVICE_MILES=25.0   # hard cap on customer->route-center distance

# Candidate identification
SMART_ASSIGNMENT_TOP_N=3                   # how many nearest routes to evaluate

# Route-ONLY scoring weights + neutral (ACTIVE ONLY when
# SMART_ASSIGNMENT_USE_ROUTE_SLOT_SCORING=false, i.e. the rollback path). The
# route-slot path (on by default below) ignores these and uses RS_WEIGHT_* +
# SLOT_HARM_* instead. Priority order: geo > capacity > window.
SMART_ASSIGNMENT_WEIGHT_GEO=0.45
SMART_ASSIGNMENT_WEIGHT_CAPACITY=0.30
SMART_ASSIGNMENT_WEIGHT_WINDOW=0.25
SMART_ASSIGNMENT_WINDOW_NEUTRAL=0.6        # window score when no preference stated
                                           # (route-only; the route-slot path drops the
                                           # factor entirely instead of using a neutral)
# Shared by BOTH scoring paths (the geo/capacity value math is reused verbatim):
SMART_ASSIGNMENT_CLUSTER_REF_MILES=15.0    # distance at which clustering score decays to ~0
SMART_ASSIGNMENT_CAPACITY_SAFETY_MARGIN=0.15 # capacity_buffer stays flat (1.0) until utilization
                                              # is within this many points of the ceiling, then
                                              # decays linearly to 0 exactly at the ceiling

# Slot selection (location- and time-aware delivery-window pick)
SMART_ASSIGNMENT_SLOT_NEIGHBORS=3          # nearest committed stops treated as "adjacent stops"
# SMART_ASSIGNMENT_SLOT_NEIGHBOR_MAX_MILES= # optional cap: ignore committed stops beyond this many miles
SMART_ASSIGNMENT_SLOT_WINDOW_MINUTES=180   # length of each candidate window (180 = 3h), centered on its time
SMART_ASSIGNMENT_SLOT_CLUSTER_GAP=180      # reference times farther apart than this start a new time-cluster
SMART_ASSIGNMENT_SLOT_CANDIDATES=3         # top-N candidate slots kept per route (pref-overlapping ones always kept)
# Blend weights for ranking/picking candidate slots (normalized over active terms).
# fit + contention shape the top-N candidate MENU in BOTH paths; the single-slot
# blend PICK (which adds preference) is used by the route-only + slotpick paths --
# the route-slot path re-scores each candidate independently and ignores this pick.
SMART_ASSIGNMENT_SLOT_WEIGHT_FIT=0.5        # proximity-weight share of the slot's cluster
SMART_ASSIGNMENT_SLOT_WEIGHT_CONTENTION=0.2 # emptier (fewer overlapping committed stops) is better
SMART_ASSIGNMENT_SLOT_WEIGHT_PREFERENCE=0.3 # overlap with the customer's stated preferred slot

# Decision / escalation
# Route-ONLY auto-assign bar (ACTIVE ONLY when SMART_ASSIGNMENT_USE_ROUTE_SLOT_SCORING
# =false). The winning route's own total_score (see shared/scoring.score_candidate)
# must meet this bar to auto-assign; below it, the agent escalates to a human. It is
# intentionally NOT a function of how close a runner-up scored. The route-slot path
# uses SMART_ASSIGNMENT_ROUTE_SLOT_SCORE_THRESHOLD (below) instead.
SMART_ASSIGNMENT_TOTAL_SCORE_THRESHOLD=0.60

# Grounded LLM judgment (optional, opt-in). When on, the recommend/escalate
# decision is made by an LLM reasoning over a structured evidence packet of the
# raw per-candidate facts (see the judgment/ package), instead of the weighted-
# sum + TOTAL_SCORE_THRESHOLD gate above. Hard constraints still run first and
# remain the only thing that can eliminate a candidate. Off by default in code
# (Config); enabled here in the sample to exercise the LLM-reasoning path. Needs
# an LLM backend + credentials; without them it transparently falls back.
SMART_ASSIGNMENT_USE_GROUNDED_JUDGMENT=true
# k -- independent judgment samples drawn for an "escalation-side" case (first
# sample is not a confident recommendation). 1 disables resampling.
SMART_ASSIGNMENT_JUDGMENT_SAMPLE_COUNT=3
# How the k samples' decisions clear back to a recommend: unanimous | majority.
SMART_ASSIGNMENT_JUDGMENT_CONSENSUS=unanimous
# Whether a LOW-confidence recommend is treated as escalation-side (resample) or
# shipped as-is. A hard ESCALATE always resamples regardless.
SMART_ASSIGNMENT_JUDGMENT_RETRY_ON_LOW_CONFIDENCE=true

# Escalation triage (optional sub-agent). When on, root_agent consults an
# `escalation_triage` AgentTool (see the triage/ package) on any escalation to
# compose a specialist brief (root cause + remediation options + a question)
# before the request_input human handoff. It runs downstream of the
# deterministic decision and never changes the route, score, or decision.
# Off reverts to a bare request_input handoff.
SMART_ASSIGNMENT_USE_ESCALATION_TRIAGE=true

# Grounded slot selection (optional, opt-in). When on, after a route is chosen,
# an LLM picks the final delivery window from that route's deterministically
# enumerated candidate menu (see the slotpick/ package). It chooses by index
# over the valid set only -- it never invents a window -- and every fact it
# cites is verified against the packet; on any parse/verify failure or backend
# error it falls back to the deterministic blended pick. It only re-orders the
# already-computed candidate slots for the winning route; it never changes the
# route, score, or decision. Off keeps the deterministic blended pick. Off by
# default in code (Config); enabled here in the sample to exercise the LLM-
# reasoning path. Needs an LLM backend + credentials; without them it falls back.
# NOTE: superseded when SMART_ASSIGNMENT_USE_ROUTE_SLOT_SCORING (below) is on --
# the route-slot decision absorbs the slot pick.
SMART_ASSIGNMENT_USE_GROUNDED_SLOT_SELECTION=true

# Route-slot scoring (optional). When on, the decision UNIT becomes the (route,
# slot) pair: every candidate slot on every feasible route is scored separately,
# so slot availability (tier-weighted openness) influences which ROUTE wins --
# not just which slot within an already-chosen route (see the `routeslot`
# package). geo/capacity are route-level; window_match and slot_availability are
# slot-level, and window_match is dropped entirely (no 0.6 neutral) for a
# prospect with no stated preference. The grounded route-slot decision (when
# SMART_ASSIGNMENT_USE_GROUNDED_JUDGMENT is on) reasons over the route-slot
# options and absorbs the separate slotpick pass; recommend-vs-escalate stays a
# deterministic threshold gate. Off in code (Config) so the prior route-only
# behavior is the rollback; enabled here in the sample.
SMART_ASSIGNMENT_USE_ROUTE_SLOT_SCORING=true
# Route-slot factor weights (kept separate from the route-only WEIGHT_* above so
# the rollback path is byte-identical). Normalized over active factors.
SMART_ASSIGNMENT_RS_WEIGHT_GEO=0.35
SMART_ASSIGNMENT_RS_WEIGHT_CAPACITY=0.25
SMART_ASSIGNMENT_RS_WEIGHT_WINDOW=0.20         # only counts when a preference is stated
SMART_ASSIGNMENT_RS_WEIGHT_AVAILABILITY=0.20
# Slot-openness "harm" weights: how costly it is to add the prospect to a window
# already held by a committed stop of each tier (higher = protect more). Ordering
# per ops: tier 5 / Perks > tier 4 > the prospect > Other. openness =
# 1 / (1 + sum of harm over overlapping committed stops).
SMART_ASSIGNMENT_SLOT_HARM_HIGH=1.0            # tier "5" / "Perks"
SMART_ASSIGNMENT_SLOT_HARM_MID=0.6             # tier "4"
SMART_ASSIGNMENT_SLOT_HARM_LOW=0.1             # "Other"
SMART_ASSIGNMENT_SLOT_HARM_UNKNOWN=0.4         # tier not known in the data
# Auto-assign bar for the route-slot path (the chosen route-slot's own total must
# meet it, else escalate). A touch below the route-only 0.60: the new composition
# drops the 0.6 window neutral and adds availability, and ops asked to err
# slightly toward recommending.
# NOTE: this bar GATES recommend-vs-escalate only when
# SMART_ASSIGNMENT_USE_GROUNDED_ROUTE_SLOT_ESCALATION (below) is false. When that
# is on (the default), the LLM decides recommend-vs-escalate itself and this value
# is demoted to a reference fact in the evidence packet.
SMART_ASSIGNMENT_ROUTE_SLOT_SCORE_THRESHOLD=0.55
# Let the LLM make the recommend-vs-escalate call on the route-slot path (default
# on). It reasons over ALL feasible route-slots -- NOT gated by the bar above -- and
# either recommends the best or ESCALATEs when it judges none good enough; an
# escalation-side/low-confidence call is resampled SMART_ASSIGNMENT_JUDGMENT_SAMPLE_COUNT
# times and combined by SMART_ASSIGNMENT_JUDGMENT_CONSENSUS before it may auto-assign.
# Grounded + verified like every other LLM call, with the deterministic threshold
# decision as the fallback on any failure. Set false to gate on the bar above and
# have the LLM only pick among above-bar options (reproducible rollback).
SMART_ASSIGNMENT_USE_GROUNDED_ROUTE_SLOT_ESCALATION=false

# --- Agent evaluation (eval TEST runners, local dev cost knobs only) ---
#
# Both optional; unset reproduces the default eval run (the full committed
# dataset, ADK's own num_runs=2). See "Running a subset locally while
# developing" in eval/README.md.
#
# Comma-separated eval_id subset to run (see eval/golden_cases.py). A LOCAL,
# shell-only knob for the test runners (test_eval.py, test_quality.py,
# test_rationale_faithfulness.py). Prefer setting it inline on the command line
# rather than here: eval.capture ignores it (use its --ids flag instead), and
# select_cases REJECTS it when CI=true so CI always scores the full golden set --
# but leaving it in .env still risks narrowing your own local test runs.
# SMART_ASSIGNMENT_EVAL_IDS=woodlands_fresh_cafe_recommend
#
# Override ADK's default of running each case twice -- 1 halves eval cost.
# SMART_ASSIGNMENT_EVAL_NUM_RUNS=1

