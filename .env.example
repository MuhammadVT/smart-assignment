# Copy this file to .env and fill in real values. Never commit .env itself.
#
# NOTE: The local demo (scripts/run_local.py) runs fully OFFLINE and needs
# NONE of these. They only matter when you turn on the LLM reasoning layer
# or deploy the ADK graph.
#
# The web app (scripts/run_web.py, or `uvicorn smart_assignment.webapp.app:app`
# directly) loads a .env file in the current directory automatically -- no need
# to export these in your shell first.

# --- Web app mode (see smart_assignment/webapp) ---
#
# Selects the "brain" behind the chat web app (scripts/run_web.py):
# "llm"           → Phase 2 (DEFAULT): the real ADK agent drives a genuine
#                   multi-turn natural-language conversation, decides which
#                   pipeline tool to call, and escalates to a human when needed.
#                   Uses the LLM backend + credentials below; if none are
#                   detected it transparently falls back to deterministic mode,
#                   so the app still runs offline.
# "deterministic" → Phase 1: a no-LLM parser fills in address/cases/slot and
#                   runs the pipeline directly. Fully offline, no key.
# Either way the live step-by-step visualization is identical.
SMART_ASSIGNMENT_WEBAPP_MODE=llm

# --- LLM backend (see smart_assignment/shared/llm.py) ---
#
# "sage"     → Sysco enterprise-governed path via SageLlmRegistry (default).
#              Requires the three SAGE_* credentials below.
# "standard" → SMART_ASSIGNMENT_MODEL below is used directly. Either a bare
#              Gemini model name (requires GOOGLE_API_KEY or Vertex
#              credentials), or a litellm-style "<provider>/<model>" string
#              for any other provider (e.g. "openai/gpt-4o-mini",
#              "anthropic/claude-3-7-sonnet-latest") -- that provider's own
#              env vars apply (e.g. OPENAI_API_KEY), and this needs the
#              `litellm` extra installed: pip install -e ".[litellm]"
SMART_ASSIGNMENT_LLM_BACKEND=sage

# --- Sage backend credentials (required when SMART_ASSIGNMENT_LLM_BACKEND=sage) ---
SAGE_CLIENT_ID=your_sage_client_id_here
SAGE_CLIENT_SECRET=your_sage_client_secret_here
SAGE_ENVIRONMENT=your_sage_environment_here

# Sage model identifier (Sage-prefixed)
SMART_ASSIGNMENT_SAGE_MODEL=sage-gemini-2.5-flash

# --- Standard backend ---

# Option A: Google AI Studio, bare Gemini model name (simplest for local dev)
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# GOOGLE_API_KEY=your_ai_studio_api_key_here

# Option B: Vertex AI, bare Gemini model name (production / Agent Runtime)
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# Option C: any litellm-supported provider, e.g. OpenAI
# SMART_ASSIGNMENT_LLM_BACKEND=standard
# OPENAI_API_KEY=your_openai_api_key_here
# SMART_ASSIGNMENT_MODEL=openai/gpt-4o-mini

# Model identifier for the standard backend (see options above)
SMART_ASSIGNMENT_MODEL=gemini-2.5-flash

# --- Route data source (see smart_assignment/integrations/route_capacity_client.py) ---
#
# "mock"     → built-in Houston demo routes (default; fully offline).
# "prepared" → routes built from ODI SQL via smart_assignment/data_prep/
#              prep_dlvry_tw_data.py. Tries live SQL first (requires creds.json
#              at the repo root), then falls back to data/dev/routes.csv.gz.
SMART_ASSIGNMENT_ROUTE_SOURCE=mock

# ds_utils run mode: local | dev | qa | perf | preprod | prod
# (see smart_assignment/data_prep/prep_dlvry_tw_data.py)
DS_UTILS_RUN_MODE=dev

# --- Workflow configuration (see smart_assignment/shared/config.py) ---

# Hard constraints
SMART_ASSIGNMENT_MAX_UTILIZATION=0.90     # max route utilization after adding a customer
SMART_ASSIGNMENT_MAX_SERVICE_MILES=25.0   # hard cap on customer->route-center distance

# Candidate identification
SMART_ASSIGNMENT_TOP_N=3                   # how many nearest routes to evaluate

# Scoring factor weights (priority order: geo > capacity > window)
SMART_ASSIGNMENT_WEIGHT_GEO=0.45
SMART_ASSIGNMENT_WEIGHT_CAPACITY=0.30
SMART_ASSIGNMENT_WEIGHT_WINDOW=0.25
SMART_ASSIGNMENT_CLUSTER_REF_MILES=15.0    # distance at which clustering score decays to ~0
SMART_ASSIGNMENT_WINDOW_NEUTRAL=0.6        # window score when no preference stated
SMART_ASSIGNMENT_CAPACITY_SAFETY_MARGIN=0.15 # capacity_buffer stays flat (1.0) until utilization
                                              # is within this many points of the ceiling, then
                                              # decays linearly to 0 exactly at the ceiling

# Decision / escalation
# The winning route's own total_score (see shared/scoring.score_candidate) must
# meet this bar to auto-assign; below it, the agent escalates to a human. This
# is intentionally NOT a function of how close a runner-up scored -- a route's
# own merit is judged on its own.
SMART_ASSIGNMENT_TOTAL_SCORE_THRESHOLD=0.60

