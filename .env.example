# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Model access (choose ONE of the two auth modes below) ---

# Option A: Google AI Studio (simplest for local dev)
GOOGLE_API_KEY=your_ai_studio_api_key_here

# Option B: Vertex AI (recommended for production / Agent Runtime deployment)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Workflow configuration (see smart_assignment/shared/config.py) ---

# Max fraction of rated vehicle capacity a route may be filled to after
# assigning a new customer. [ASSUMPTION] confirm real value with ops.
SMART_ASSIGNMENT_MAX_UTILIZATION=0.90

# Confidence threshold below which slot_recommendation escalates to a
# human reviewer instead of auto-committing.
SMART_ASSIGNMENT_CONFIDENCE_THRESHOLD=0.70

# Default Gemini model used across workflows unless a workflow overrides it.
SMART_ASSIGNMENT_MODEL=gemini-flash-latest
